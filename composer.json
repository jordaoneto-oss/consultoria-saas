{
    "name": "consultoria/platform",
    "description": "Consultoria SaaS - Marketplace de Consultoria de Negócios e Tecnologia",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=8.0",
        "composer/installers": "^2.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "mockery/mockery": "^1.6",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-phpunit/wp-phpunit": "^6.0",
        "yoast/phpunit-polyfills": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Consultoria\\": "wp-content/plugins/consultoria-platform/src/",
            "Consultoria\\Modules\\": "wp-content/plugins/consultoria-platform/modules/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration",
        "lint": "phpcs wp-content/plugins/consultoria-platform --standard=PSR12",
        "lint:fix": "phpcbf wp-content/plugins/consultoria-platform --standard=PSR12",
        "check": [
            "@lint",
            "@test"
        ]
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "extra": {
        "installer-paths": {
            "wp-content/plugins/{$name}/": ["type:wordpress-plugin"]
        }
    }
}
